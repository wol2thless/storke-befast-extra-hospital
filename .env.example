# ==============================================================
#  ไฟล์ตัวอย่าง — คัดลอกเป็น .env แล้วแก้ค่าให้ตรงกับ server
# ==============================================================

# Base path ของแอป — ชื่อ folder ที่วาง project ไว้บน server
# ถ้าวางที่ root ของ domain ให้ใส่ /
# ตัวอย่าง: /stroke-befast  หรือ  /health-app  หรือ  /
VITE_BASE_PATH=/stroke-befast

# URL ของ backend API (ชี้ไปที่ server ที่ deploy backend ไว้)
# ตัวอย่าง: http://192.168.1.100/stroke-befast/backend/api
VITE_API_BASE_URL=http://YOUR_SERVER_IP/stroke-befast/backend/api

# URL ของ HIS สำหรับ Vite dev proxy (ใช้ตอน npm run dev เท่านั้น ไม่กระทบ production)
VITE_HIS_PROXY_TARGET=http://YOUR_HIS_SERVER_IP

# URL ตรงของ HIS Appointment endpoint (ใช้ใน API Tester เมื่อปิด proxy)
# ถ้ายังไม่มี HIS ให้เว้นว่าง
VITE_HIS_APPOINTMENT_URL=

# ThaiD OAuth2 Client ID — ขอจาก DOPA หรือผู้ดูแล ThaiD ของโรงพยาบาล
# อ่านวิธีขอได้ที่ backend/docs/thaid_setup_guide.md
VITE_THAID_CLIENT_ID=YOUR_THAID_CLIENT_ID

# ลิงก์คู่มือและช่องทางการติดต่อ (ใส่ลิงก์ของโรงพยาบาลเอง หรือเว้นว่างถ้าไม่มี)
VITE_MANUAL_URL=https://YOUR_MANUAL_LINK
VITE_ASSESSMENT_FORM_URL=https://YOUR_ASSESSMENT_FORM_LINK
VITE_ADMIN_MANUAL_URL=https://YOUR_ADMIN_MANUAL_LINK
VITE_MANUAL_PDF_URL=https://YOUR_PDF_MANUAL_LINK
VITE_LINE_OA_URL=https://YOUR_LINE_OA_LINK
