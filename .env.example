# ==============================================================
#  ไฟล์ตัวอย่าง — คัดลอกเป็น .env แล้วแก้ค่าให้ตรงกับ server
# ==============================================================

# URL ของ backend API (ชี้ไปที่ server ที่ deploy backend ไว้)
# ตัวอย่าง: http://192.168.1.100/stroke-befast/backend/api
VITE_API_BASE_URL=http://YOUR_SERVER_IP/stroke-befast/backend/api

# URL ของ HIS สำหรับ Vite dev proxy (ใช้ตอน npm run dev เท่านั้น ไม่กระทบ production)
VITE_HIS_PROXY_TARGET=http://YOUR_HIS_SERVER_IP
